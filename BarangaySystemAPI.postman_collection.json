            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" },{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"admin1234\",\n  \"new_password\": \"newSecurePass123\"\n}" },
            "url": { "raw": "{{base_url}}/admin/profile/password", "host": ["{{base_url}}"], "path": ["admin","profile","password"] }
          }
