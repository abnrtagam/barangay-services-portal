{
  "info": {
    "name": "Barangay Bulua Service Portal API",
    "description": "Complete API collection for the Barangay Bulua Digital Service Portal. Covers authentication, admin management, resident features, and public endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "resident_token", "value": "", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "user_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Resident",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "first_name", "value": "Juan", "type": "text" },
                { "key": "last_name", "value": "Dela Cruz", "type": "text" },
                { "key": "email", "value": "juan.dc@example.com", "type": "text" },
                { "key": "phone", "value": "09123456789", "type": "text" },
                { "key": "address", "value": "P-1, Barangay Bulua, CDO", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" },
                { "key": "documents", "type": "file", "description": "Upload verification documents (max 3)" }
              ]
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] },
            "description": "Register a new resident account"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"juan.dc@example.com\",\n  \"otp\": \"123456\"\n}" },
            "url": { "raw": "{{base_url}}/auth/verify-otp", "host": ["{{base_url}}"], "path": ["auth","verify-otp"] },
            "description": "Verify email with OTP code"
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"juan.dc@example.com\"\n}" },
            "url": { "raw": "{{base_url}}/auth/resend-otp", "host": ["{{base_url}}"], "path": ["auth","resend-otp"] }
          }
        },
        {
          "name": "Resident Login",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) {","    const r = pm.response.json();","    pm.collectionVariables.set('resident_token', r.token);","    pm.collectionVariables.set('user_id', r.user.id);","}"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"juan.dc@example.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] },
            "description": "Login as resident. Token auto-saved."
          }
        },
        {
          "name": "Admin Login",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) {","    const r = pm.response.json();","    pm.collectionVariables.set('admin_token', r.token);","}"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@bulua.gov.ph\",\n  \"password\": \"admin1234\"\n}" },
            "url": { "raw": "{{base_url}}/auth/admin-login", "host": ["{{base_url}}"], "path": ["auth","admin-login"] },
            "description": "Login as admin. Token auto-saved."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"juan.dc@example.com\"\n}" },
            "url": { "raw": "{{base_url}}/auth/forgot-password", "host": ["{{base_url}}"], "path": ["auth","forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"juan.dc@example.com\",\n  \"otp\": \"123456\",\n  \"new_password\": \"newpassword123\"\n}" },
            "url": { "raw": "{{base_url}}/auth/reset-password", "host": ["{{base_url}}"], "path": ["auth","reset-password"] }
          }
        }
      ]
    },
    {
      "name": "Admin - Dashboard",
      "item": [
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/stats", "host": ["{{base_url}}"], "path": ["admin","stats"] }
          }
        },
        {
          "name": "Get Daily Stats (7-day)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/daily-stats", "host": ["{{base_url}}"], "path": ["admin","daily-stats"] }
          }
        }
      ]
    },
    {
      "name": "Admin - Complaints",
      "item": [
        {
          "name": "Get All Complaints",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/complaints?page=1&limit=20", "host": ["{{base_url}}"], "path": ["admin","complaints"], "query": [{ "key": "page", "value": "1" },{ "key": "limit", "value": "20" }] }
          }
        },
        {
          "name": "Filter Complaints by Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/complaints?status=Pending", "host": ["{{base_url}}"], "path": ["admin","complaints"], "query": [{ "key": "status", "value": "Pending" }] }
          }
        },
        {
          "name": "Update Complaint Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" },{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Approved\",\n  \"admin_remarks\": \"Complaint verified and approved for action.\"\n}" },
            "url": { "raw": "{{base_url}}/admin/complaints/1/status", "host": ["{{base_url}}"], "path": ["admin","complaints","1","status"] }
          }
        }
      ]
    },
    {
      "name": "Admin - Appointments",
      "item": [
        {
          "name": "Get All Appointments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/appointments?page=1&limit=20", "host": ["{{base_url}}"], "path": ["admin","appointments"], "query": [{ "key": "page", "value": "1" },{ "key": "limit", "value": "20" }] }
          }
        },
        {
          "name": "Update Appointment Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" },{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Approved\",\n  \"admin_remarks\": \"Appointment confirmed.\"\n}" },
            "url": { "raw": "{{base_url}}/admin/appointments/1/status", "host": ["{{base_url}}"], "path": ["admin","appointments","1","status"] }
          }
        }
      ]
    },
    {
      "name": "Admin - Residents",
      "item": [
