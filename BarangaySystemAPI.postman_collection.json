          "name": "Get All Accounts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/verifications", "host": ["{{base_url}}"], "path": ["admin","verifications"] }
          }
        },
