    {
      "name": "Admin - Verification",
      "item": [
        {
          "name": "Get Verification Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/verifications/stats", "host": ["{{base_url}}"], "path": ["admin","verifications","stats"] }
