          "name": "Get Reactivation Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/verifications/reactivation-requests", "host": ["{{base_url}}"], "path": ["admin","verifications","reactivation-requests"] }
          }
        },
        {
          "name": "Get Account Details",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/verifications/{{user_id}}", "host": ["{{base_url}}"], "path": ["admin","verifications","{{user_id}}"] }
          }
        },
        {
          "name": "Approve Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" },{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Documents verified. Account approved.\"\n}" },
            "url": { "raw": "{{base_url}}/admin/verifications/{{user_id}}/approve", "host": ["{{base_url}}"], "path": ["admin","verifications","{{user_id}}","approve"] }
          }
        },
        {
          "name": "Reject Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" },{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Documents incomplete — resubmit with clearer images.\"\n}" },
            "url": { "raw": "{{base_url}}/admin/verifications/{{user_id}}/reject", "host": ["{{base_url}}"], "path": ["admin","verifications","{{user_id}}","reject"] }
          }
        }
      ]
    },
    {
      "name": "Admin - Reports",
      "item": [
