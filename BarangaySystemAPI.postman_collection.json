          "name": "Get All Residents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/residents?page=1&limit=20", "host": ["{{base_url}}"], "path": ["admin","residents"], "query": [{ "key": "page", "value": "1" },{ "key": "limit", "value": "20" }] }
          }
        },
        {
          "name": "Search Residents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/residents?search=Juan", "host": ["{{base_url}}"], "path": ["admin","residents"], "query": [{ "key": "search", "value": "Juan" }] }
          }
        },
        {
          "name": "Get Zone Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/residents/zone-stats", "host": ["{{base_url}}"], "path": ["admin","residents","zone-stats"] }
