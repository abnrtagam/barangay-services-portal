# ──────────────────────────────────────────────────────────────
# Barangay Bulua Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MySQL / XAMPP
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=barangay_complaint_system

# JWT Authentication
# Use a strong, unique secret in production (min 32 characters)
JWT_SECRET=CHANGE_ME_to_a_strong_random_string
JWT_EXPIRES_IN=7d

# Gmail SMTP (for OTP and notification emails)
# 1. Enable 2-Step Verification on your Google Account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Paste the 16-character App Password below (no spaces)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Laravel backend URL (if using Laravel admin panel)
LARAVEL_BASE_URL=http://localhost:8000/api

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Frontend URL (used for CORS and email redirect links)
# Change to your production domain when deploying
FRONTEND_URL=http://localhost:3000
